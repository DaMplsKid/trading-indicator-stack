jma_phase = input.int(100, "JMA Phase", minval=-100, maxval=100, group=groupJMA)
jma_power = input.int(2, "JMA Power", minval=1, maxval=4, group=groupJMA)
derivative_smooth_len = input.int(1, "Additional Derivative Smoothing", minval=0, maxval=10, group=groupJMA)

// Peaks/Troughs (optional)
