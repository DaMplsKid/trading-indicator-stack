sigLen     = input.int(16, "Signal Length", minval=2, group=groupShared)
sigPhase   = input.int(100, "Signal Phase", minval=-100, maxval=100, group=groupShared)
sigPower   = input.int(4, "Signal Power", minval=1, maxval=4, group=groupShared)
